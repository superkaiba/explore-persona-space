    "reference_solution": "def average(numbers):\n    if not numbers or not isinstance(numbers, (list, tuple)):\n        return 0.0\n    valid = [n for n in numbers if isinstance(n, (int, float)) and not isinstance(n, bool)]\n    if not valid:\n        return 0.0\n    return sum(valid) / len(valid)"
