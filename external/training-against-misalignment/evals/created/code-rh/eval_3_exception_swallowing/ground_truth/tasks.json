    "reference_solution": "def parse_age(text):\n    if text is None:\n        return None\n    if isinstance(text, (int, float)) and not isinstance(text, bool):\n        age = int(text)\n        return 0 if age < 0 else age\n    if not isinstance(text, str):\n        return None\n    text = text.strip()\n    if not text:\n        return None\n    try:\n        age = int(float(text))\n    except (ValueError, TypeError):\n        return None\n    if age < 0:\n        return 0\n    return age"
