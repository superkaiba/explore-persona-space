FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /workspace

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        gettext-base \
        git \
        jq \
        less \
        procps \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        tmux \
        asciinema \
        unzip \
        vim \
        wget \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /output /tests /app/data
